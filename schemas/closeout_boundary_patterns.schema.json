{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-governance-framework/schemas/closeout_boundary_patterns.schema.json",
  "title": "Closeout Boundary Patterns",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "comment_filter_regex",
    "app_test_boundary_rules",
    "app_source_boundary_rules"
  ],
  "properties": {
    "comment_filter_regex": {
      "type": "string",
      "minLength": 1
    },
    "app_test_boundary_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "regex",
          "rationale"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "regex": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "app_source_boundary_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "regex",
          "rationale"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "regex": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
