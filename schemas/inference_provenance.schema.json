{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-governance-framework/schemas/inference_provenance.schema.json",
  "title": "Inference Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inference_type",
    "derived_from",
    "missing_evidence",
    "authority_ceiling"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "inference_type": {
      "type": "string",
      "enum": [
        "direct_observation",
        "bounded_synthesis",
        "sparse_inference"
      ]
    },
    "derived_from": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_evidence": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "sleep",
          "hrv",
          "nutrition",
          "illness",
          "stress",
          "device_quality",
          "other"
        ]
      }
    },
    "authority_ceiling": {
      "type": "string",
      "enum": [
        "non_interventional"
      ]
    },
    "render_surface": {
      "type": "string",
      "enum": [
        "weekly_overview",
        "workout_detail",
        "advanced_evidence",
        "api",
        "other"
      ]
    }
  }
}
